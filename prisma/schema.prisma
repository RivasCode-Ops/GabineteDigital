generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  ADMIN
  COORDENADOR_GERAL
  COORDENADOR_REGIONAL
  COORDENADOR_MUNICIPAL
  LIDERANCA
  OPERADOR
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        RoleName @unique
  level       Int      @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String    @db.VarChar(255)
  email               String    @unique @db.VarChar(255)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  roleId              String    @map("role_id") @db.Uuid
  role                Role      @relation(fields: [roleId], references: [id])
  phone               String?   @db.VarChar(20)
  avatarUrl           String?   @map("avatar_url") @db.VarChar(500)
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at")
  passwordResetToken  String?   @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires DateTime? @map("password_reset_expires")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  auditLogs           AuditLog[]
  createdPeople       Person[]  @relation("created_by")
  assignedDemands     Demand[]  @relation("assigned_to")
  assignedByDemands   Demand[]  @relation("assigned_by")
  createdDemands      Demand[]  @relation("demand_creator")
  activities          Activity[]
  createdEvents       Event[]   @relation("event_creator")
  surveys             Survey[]
  notifications       Notification[]

  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  action    String   @db.VarChar(50)
  entity    String   @db.VarChar(50)
  entityId  String?  @map("entity_id") @db.VarChar(50)
  changes   Json?    @db.JsonB
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

enum TerritoryType {
  state
  region
  city
  neighborhood
  community
}

model Territory {
  id          String          @id @default(uuid()) @db.Uuid
  name        String          @db.VarChar(255)
  type        TerritoryType
  parentId    String?         @map("parent_id") @db.Uuid
  parent      Territory?      @relation("TerritoryHierarchy", fields: [parentId], references: [id])
  children    Territory[]     @relation("TerritoryHierarchy")
  slug        String          @unique @db.VarChar(255)
  population  Int?
  ibgeCode    String?         @map("ibge_code") @db.VarChar(10)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")
  people      Person[]
  demands     Demand[]
  activities  Activity[]
  events      Event[]
  surveys     Survey[]
  leaderships Leadership[]
  metrics     TerritoryMetric?
  alerts      Alert[]

  @@index([parentId])
  @@index([type])
  @@index([parentId, type])
  @@map("territories")
}

enum PersonCategory {
  lideranca
  morador
  empresario
  vereador
  ex_vereador
  presidente_associacao
  sindicato
  influenciador
  parceiro_institucional
}

model Person {
  id             String         @id @default(uuid()) @db.Uuid
  name           String         @db.VarChar(255)
  phone          String         @db.VarChar(20)
  email          String?        @db.VarChar(255)
  category       PersonCategory
  territoryId    String?        @map("territory_id") @db.Uuid
  territory      Territory?     @relation(fields: [territoryId], references: [id])
  contactOrigin  String?        @map("contact_origin") @db.VarChar(100)
  notes          String?        @db.Text
  consentGiven   Boolean        @default(false) @map("consent_given")
  consentIp      String?        @map("consent_ip") @db.VarChar(45)
  consentVersion String?        @map("consent_version") @db.VarChar(10)
  consentAt      DateTime?      @map("consent_at")
  isActive       Boolean        @default(true) @map("is_active")
  createdBy      String?        @map("created_by") @db.Uuid
  creator        User?          @relation("created_by", fields: [createdBy], references: [id])
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  demands        Demand[]       @relation("requester")
  leaderships    Leadership[]   @relation("leader")
  supervised     Leadership[]   @relation("superior")
  participations EventParticipant[]

  @@index([phone])
  @@index([territoryId])
  @@index([category])
  @@index([createdBy])
  @@map("people")
}

model Leadership {
  id            String    @id @default(uuid()) @db.Uuid
  leaderId      String    @map("leader_id") @db.Uuid
  leader        Person    @relation("leader", fields: [leaderId], references: [id])
  superiorId    String?   @map("superior_id") @db.Uuid
  superior      Person?   @relation("superior", fields: [superiorId], references: [id])
  role          String    @db.VarChar(100)
  territoryId   String?   @map("territory_id") @db.Uuid
  territory     Territory? @relation(fields: [territoryId], references: [id])
  isCoordinator Boolean   @default(false) @map("is_coordinator")
  startDate     DateTime  @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([leaderId])
  @@index([superiorId])
  @@index([territoryId])
  @@index([isActive])
  @@map("leadership_network")
}

enum DemandStatus {
  recebida
  triagem
  encaminhada
  acompanhamento
  resolvida
  encerrada
  arquivada
}

enum DemandCategory {
  saude
  educacao
  infraestrutura
  transporte
  agricultura
  assistencia_social
  regularizacao_fundiaria
  outro
}

enum DemandPriority {
  baixa
  media
  alta
  urgente
}

model Demand {
  id           String         @id @default(uuid()) @db.Uuid
  title        String         @db.VarChar(255)
  description  String?        @db.Text
  category     DemandCategory
  status       DemandStatus   @default(recebida)
  priority     DemandPriority @default(media)
  territoryId  String?        @map("territory_id") @db.Uuid
  territory    Territory?     @relation(fields: [territoryId], references: [id])
  requesterId  String?        @map("requester_id") @db.Uuid
  requester    Person?        @relation("requester", fields: [requesterId], references: [id])
  assignedTo   String?        @map("assigned_to") @db.Uuid
  assignee     User?          @relation("assigned_to", fields: [assignedTo], references: [id])
  assignedBy   String?        @map("assigned_by") @db.Uuid
  assigner     User?          @relation("assigned_by", fields: [assignedBy], references: [id])
  solution     String?        @db.Text
  resolvedAt   DateTime?      @map("resolved_at")
  closedAt     DateTime?      @map("closed_at")
  createdBy    String?        @map("created_by") @db.Uuid
  creator      User?          @relation("demand_creator", fields: [createdBy], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")
  history      DemandHistory[]

  @@index([status])
  @@index([category])
  @@index([territoryId])
  @@index([requesterId])
  @@index([assignedTo])
  @@index([priority])
  @@index([createdAt])
  @@map("demands")
}

model DemandHistory {
  id        String   @id @default(uuid()) @db.Uuid
  demandId  String   @map("demand_id") @db.Uuid
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  field     String   @db.VarChar(50)
  oldValue  String?  @map("old_value") @db.Text
  newValue  String?  @map("new_value") @db.Text
  changedBy String?  @map("changed_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@index([demandId])
  @@index([changedBy])
  @@map("demand_history")
}

enum ActivityType {
  visita
  reuniao
  evento
  ligacao
  atendimento
}

model Activity {
  id           String       @id @default(uuid()) @db.Uuid
  type         ActivityType
  title        String       @db.VarChar(255)
  description  String?      @db.Text
  territoryId  String?      @map("territory_id") @db.Uuid
  territory    Territory?   @relation(fields: [territoryId], references: [id])
  peopleIds    Json?        @map("people_ids") @db.JsonB
  performedBy  String?      @map("performed_by") @db.Uuid
  performer    User?        @relation(fields: [performedBy], references: [id])
  performedAt  DateTime     @map("performed_at")
  durationMin  Int?         @map("duration_min")
  location     String?      @db.VarChar(255)
  notes        String?      @db.Text
  isPublic     Boolean      @default(false) @map("is_public")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  @@index([type])
  @@index([territoryId])
  @@index([performedBy])
  @@index([performedAt])
  @@map("activities")
}

enum EventType {
  reuniao
  evento
  audiencia
  viagem
  visita
  entrevista
}

enum EventStatus {
  scheduled
  confirmed
  cancelled
  completed
}

model Event {
  id           String            @id @default(uuid()) @db.Uuid
  title        String            @db.VarChar(255)
  description  String?           @db.Text
  type         EventType
  territoryId  String?           @map("territory_id") @db.Uuid
  territory    Territory?        @relation(fields: [territoryId], references: [id])
  startAt      DateTime          @map("start_at")
  endAt        DateTime          @map("end_at")
  allDay       Boolean           @default(false) @map("all_day")
  location     String?           @db.VarChar(255)
  address      String?           @db.Text
  createdBy    String?           @map("created_by") @db.Uuid
  creator      User?             @relation("event_creator", fields: [createdBy], references: [id])
  status       EventStatus       @default(scheduled)
  notes        String?           @db.Text
  color        String?           @db.VarChar(7)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  deletedAt    DateTime?         @map("deleted_at")
  participants EventParticipant[]

  @@index([type])
  @@index([territoryId])
  @@index([startAt, endAt])
  @@index([createdBy])
  @@index([status])
  @@map("events")
}

model EventParticipant {
  id        String @id @default(uuid()) @db.Uuid
  eventId   String @map("event_id") @db.Uuid
  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  personId  String @map("person_id") @db.Uuid
  person    Person @relation(fields: [personId], references: [id])
  role      String? @db.VarChar(100)
  confirmed Boolean @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([eventId, personId])
  @@index([eventId])
  @@index([personId])
  @@map("event_participants")
}

enum Sentiment {
  muito_favoravel
  favoravel
  neutro
  resistente
  muito_resistente
}

model Survey {
  id           String            @id @default(uuid()) @db.Uuid
  title        String            @db.VarChar(255)
  territoryId  String?           @map("territory_id") @db.Uuid
  territory    Territory?        @relation(fields: [territoryId], references: [id])
  collectedBy  String?           @map("collected_by") @db.Uuid
  collector    User?             @relation(fields: [collectedBy], references: [id])
  collectedAt  DateTime          @map("collected_at")
  sentiment    Sentiment
  problems     Json?             @db.JsonB
  priorities   Json?             @db.JsonB
  notes        String?           @db.Text
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  deletedAt    DateTime?         @map("deleted_at")
  questions    SurveyQuestion[]

  @@index([territoryId])
  @@index([collectedBy])
  @@index([sentiment])
  @@index([collectedAt])
  @@map("surveys")
}

enum AnswerType {
  text
  number
  multiple_choice
  scale
}

model SurveyQuestion {
  id         String     @id @default(uuid()) @db.Uuid
  surveyId   String     @map("survey_id") @db.Uuid
  survey     Survey     @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question   String     @db.Text
  answer     String?    @db.Text
  answerType AnswerType @default(text) @map("answer_type")
  options    Json?      @db.JsonB
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([surveyId])
  @@map("survey_questions")
}

model TerritoryMetric {
  id              String   @id @default(uuid()) @db.Uuid
  territoryId     String   @unique @map("territory_id") @db.Uuid
  territory       Territory @relation(fields: [territoryId], references: [id])
  peopleCount     Int      @default(0) @map("people_count")
  leadersCount    Int      @default(0) @map("leaders_count")
  demandsCount    Int      @default(0) @map("demands_count")
  openDemands     Int      @default(0) @map("open_demands")
  resolvedDemands Int      @default(0) @map("resolved_demands")
  activitiesCount Int      @default(0) @map("activities_count")
  eventsCount     Int      @default(0) @map("events_count")
  surveysCount    Int      @default(0) @map("surveys_count")
  lastActivityAt  DateTime? @map("last_activity_at")
  score           Int      @default(0)
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([score])
  @@index([territoryId])
  @@map("territory_metrics")
}

enum AlertType {
  TERRITORIO_SEM_VISITA
  DEMANDA_ATRASADA
  LIDERANCA_INATIVA
  SEM_PESQUISA
  SEM_EVENTO
}

enum AlertSeverity {
  baixo
  medio
  alto
  critico
}

model Alert {
  id          String       @id @default(uuid()) @db.Uuid
  territoryId String?      @map("territory_id") @db.Uuid
  territory   Territory?   @relation(fields: [territoryId], references: [id])
  type        AlertType
  severity    AlertSeverity
  title       String       @db.VarChar(255)
  description String?      @db.Text
  metadata    Json?        @db.JsonB
  resolvedAt  DateTime?    @map("resolved_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([territoryId])
  @@index([type])
  @@index([severity])
  @@index([resolvedAt])
  @@map("alerts")
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  CRITICAL
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  user      User             @relation(fields: [userId], references: [id])
  title     String           @db.VarChar(255)
  message   String?          @db.Text
  type      NotificationType @default(INFO)
  readAt    DateTime?        @map("read_at")
  link      String?          @db.VarChar(500)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@map("notifications")
}

model MessageTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  subject   String   @db.VarChar(255)
  body      String   @db.Text
  variables Json?    @db.JsonB
  queueItems MessageQueue[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("message_templates")
}

enum QueueStatus {
  pending
  sent
  failed
}

model MessageQueue {
  id         String           @id @default(uuid()) @db.Uuid
  templateId String?          @map("template_id") @db.Uuid
  template   MessageTemplate? @relation(fields: [templateId], references: [id])
  recipient  String           @db.VarChar(255)
  channel    String           @db.VarChar(50)
  subject    String?          @db.VarChar(255)
  body       String?          @db.Text
  status     QueueStatus      @default(pending)
  sentAt     DateTime?        @map("sent_at")
  error      String?          @db.Text
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([status])
  @@map("message_queue")
}
